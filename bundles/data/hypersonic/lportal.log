ge-viewer-base-image'').setStyles(\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009{\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009height: ''auto'',\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009maxHeight: event.height,\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009maxWidth: event.width,\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009width: ''auto''\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009\u0009\u0009);\u000a\u0009\u0009\u0009\u0009\u0009}\u000a\u0009\u0009\u0009\u0009},\u000a\u000a\u0009\u0009\u0009\u0009contentBox: ''#<@portlet.namespace />carousel'',\u000a\u0009\u0009\u0009\u0009height: 250,\u000a\u0009\u0009\u0009\u0009intervalTime: 2,\u000a\u0009\u0009\u0009\u0009width: 700\u000a\u0009\u0009\u0009}\u000a\u0009\u0009).render();\u000a\u0009</@liferay_aui.script>\u000a</#if>',0,20096,NULL,'2026-03-16 13:15:44.646000')
