INSERT INTO DDMTEMPLATE VALUES(0,0,'59798f01-e13e-75b6-f52a-04c9cc3d1cf9','59798f01-e13e-75b6-f52a-04c9cc3d1cf9',31980,20120,59206091757698,20096,NULL,20096,NULL,'2026-03-16 13:15:45.125000','2026-03-16 13:15:45.125000',31891,0,31893,'SEARCH-BAR-LEFT-ALIGNED-ICON-FTL','1.0','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Name language-id="sv_SE">Layout f\u00f6r v\u00e4nsterjusterad ikon</Name><Name language-id="pt_BR">Layout do \u00cdcone Alinhado \u00e0 Esquerda</Name><Name language-id="ja_JP">\u5de6\u63c3\u3048\u306e\u30a2\u30a4\u30b3\u30f3\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="fr_FR">Disposition ic\u00f4ne align\u00e9e \u00e0 gauche</Name><Name language-id="hu_HU">Elrendez\u00e9s balra igaz\u00edtott ikonnal</Name><Name language-id="de_DE">Links ausgerichtetes Symbollayout</Name><Name language-id="ca_ES">Disposici\u00f3 de la icona alineada a l''esquerra</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0631\u0645\u0648\u0632 \u062a\u0645\u062a \u0645\u062d\u0627\u0630\u0627\u062a\u0647\u0627 \u0644\u0644\u064a\u0633\u0627\u0631</Name><Name language-id="fi_FI">Vasemmalle Tasattu Kuvakkeiden Asettelu</Name><Name language-id="en_US">Left Aligned Icon Layout</Name><Name language-id="zh_CN">\u5de6\u5bf9\u9f50\u56fe\u6807\u5e03\u5c40</Name><Name language-id="es_ES">Dise\u00f1o de icono alineado a la izquierda</Name><Name language-id="nl_NL">Lay-out met pictogram links uitgelijnd</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Description language-id="sv_SE">Visa s\u00f6kikonen till v\u00e4nster.</Description><Description language-id="pt_BR">Exibir o \u00edcone de busca \u00e0 esquerda.</Description><Description language-id="ja_JP">\u691c\u7d22\u30a2\u30a4\u30b3\u30f3\u3092\u5de6\u5074\u306b\u8868\u793a\u3057\u307e\u3059\u3002